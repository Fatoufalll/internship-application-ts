// prisma/schema.prisma
datasource db {
  provider = "postgres"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  url      = env("DATABASE_URL")
}
model DemandeStage {
  id              Int      @id @default(autoincrement())
  civilite        String
  nom             String
  prenom          String
  codePostal      String
  ville           String
  telephone       String
  email           String
  situation       String
  niveau          String
  formation       String
  etablissement   String
  ancienStagiaire String
  anneeStage      String
  niveauAncien    String
  domaine         String?
  cv_path         String
  lettre_path     String
  statut          String   @default("en_attente")
  date_creation   DateTime @default(now())
}