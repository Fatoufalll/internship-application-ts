// prisma/schema.prisma
datasource db {
  provider = "postgres"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}


model DemandeStage {
  id           Int      @id @default(autoincrement())
  nom          String
  prenom       String
  email        String
  niveau       String?
  domaine      String?
  cv_path      String?
  lettre_path  String?
  statut       String   @default("En attente")
  date_creation DateTime @default(now())
}
